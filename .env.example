# The After — environment variables
# Copy to .env.local and fill in what you have. EVERYTHING IS OPTIONAL:
# with no values set, the app runs in a fully-featured local demo mode
# (deterministic AI + private per-browser guest storage).

# --- AI (optional) ----------------------------------------------------------
# Set to enable real GPT-5.6 for intake enrichment, plans, letters, and the
# companion. Without it, a deterministic demo model is used.
OPENAI_API_KEY=
# Model id (optional; the app defaults to gpt-5.6)
OPENAI_MODEL=gpt-5.6-sol
# Optional custom/base URL for OpenAI-compatible gateways.
OPENAI_BASE_URL=

# --- Supabase (optional) ----------------------------------------------------
# Set all three to switch from the in-memory demo store to real multi-user
# accounts, Postgres persistence, and private document storage.
# Run supabase/schema.sql in your project first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App --------------------------------------------------------------------
# Public base URL (used for OAuth redirects). Defaults to the request origin.
NEXT_PUBLIC_APP_URL=
# Optional server-side base URL fallback. Defaults to http://localhost:3000.
APP_URL=
